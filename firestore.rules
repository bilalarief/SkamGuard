rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════
    // Community Phone Reports — public data
    // ═══════════════════════════════════════
    match /reported_phones/{phoneId} {
      // Anyone can read community reports
      allow read: if true;

      // Authenticated users can create new reports
      allow create: if request.auth != null
                    && request.resource.data.phoneNumber is string
                    && request.resource.data.source == 'community';

      // Authenticated users can update (increment reportCount via merge)
      allow update: if request.auth != null
                    && request.resource.data.source == 'community';
    }

    // Phone report subcollection (individual reporter records)
    match /reported_phones/{phoneId}/reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid is string;
    }

    // ═══════════════════════════════════════
    // Community URL Reports — public data
    // ═══════════════════════════════════════
    match /reports_url/{urlId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.url is string
                    && request.resource.data.source == 'community';

      allow update: if request.auth != null
                    && request.resource.data.source == 'community';
    }

    match /reports_url/{urlId}/reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid is string;
    }

    // ═══════════════════════════════════════
    // User Profiles — owner-only access
    // ═══════════════════════════════════════
    match /users/{userId} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId;

      allow update: if request.auth != null
                    && request.auth.uid == userId;
    }

    // User scan history — owner-only access
    match /users/{userId}/scan_history/{scanId} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId;

      // No update/delete — scan history is append-only
    }

    // ═══════════════════════════════════════
    // Community Scans — anonymized dataset
    // Server writes only; no client reads (analytics via admin SDK)
    // ═══════════════════════════════════════
    match /community_scans/{scanId} {
      // No client reads — data accessed via Firebase Admin for analytics
      allow read: if false;

      // Allow create from any authenticated context (server API routes)
      // Validate no PII fields are present
      allow create: if request.auth != null
                    && request.resource.data.riskScore is number
                    && request.resource.data.riskLevel is string
                    && request.resource.data.verdict is string
                    && !('phoneNumber' in request.resource.data)
                    && !('screenshot' in request.resource.data)
                    && !('imageBase64' in request.resource.data)
                    && !('email' in request.resource.data)
                    && !('uid' in request.resource.data);

      // No updates or deletes — append-only dataset
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════
    // Default deny — block everything else
    // ═══════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
