rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════
    // Community Phone Reports — public data
    // ═══════════════════════════════════════
    match /reported_phones/{phoneId} {
      // Anyone can read community reports
      allow read: if true;
      // Authenticated users (including anonymous) can create/update
      allow create, update: if request.auth != null;
    }

    // Phone report subcollection (individual reporter records)
    match /reported_phones/{phoneId}/reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // ═══════════════════════════════════════
    // Community URL Reports — public data
    // ═══════════════════════════════════════
    match /reports_url/{urlId} {
      allow read: if true;
      allow create, update: if request.auth != null;
    }

    match /reports_url/{urlId}/reporters/{reporterId} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    // ═══════════════════════════════════════
    // User Profiles — owner-only access
    // ═══════════════════════════════════════
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // User scan history — owner-only access
    match /users/{userId}/scan_history/{scanId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ═══════════════════════════════════════
    // Default deny — block everything else
    // ═══════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
